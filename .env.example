# Clerk (obrigatório para API autenticada)
CLERK_SECRET_KEY=
# Chave publicável (pk_...): no Railway pode usar só esta no serviço único — o SPA lê /clerk-frontend-config.js
CLERK_PUBLISHABLE_KEY=
# Opcional: JWKS público (se vazio, usa https://api.clerk.com/v1/jwks com CLERK_SECRET_KEY)
# CLERK_JWKS_URL=https://SEU_FRONTEND_API.clerk.accounts.dev/.well-known/jwks.json
# Origens permitidas no claim azp do JWT (separadas por vírgula). Em produção inclua a URL pública (Railway).
# O backend também aceita os mesmos hosts definidos em CORS_ORIGINS para o azp.
CLERK_AUTHORIZED_PARTIES=http://localhost:5173

# Linear webhook (POST /api/webhooks/linear — assinatura HMAC)
LINEAR_WEBHOOK_SECRET=

# SQLite local (opcional; padrão backend/data/tickets.db)
# TICKETS_DB_PATH=/data/tickets.db

# IA principal — deixe vazio para pular para Gemini
ANTHROPIC_API_KEY=
# Fallback Gemini
GCP_PROJECT_ID=
VERTEX_LOCATION=us-central1
# Caminho ao arquivo local. Na Railway preferir GCP_SERVICE_ACCOUNT_JSON (o código aceita JSON aqui também).
GOOGLE_APPLICATION_CREDENTIALS=service_account.json
LINEAR_API_KEY=
LINEAR_TEAM_ID=
LINEAR_PROJECT_ID=

# Frontend (opcional; padrão http://localhost:8000 em dev; em produção build com VITE_API_URL vazio = mesma origem)
# VITE_API_URL=http://localhost:8000
# Chave publicável Clerk (build do frontend / Railway)
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# CORS (produção: URL pública do browser, separada por vírgula). Usada também para validar azp do Clerk.
# CORS_ORIGINS=https://seu-app.up.railway.app,http://localhost:5173

# Railway / GCP: JSON inteiro da service account (alternativa ao arquivo service_account.json)
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
